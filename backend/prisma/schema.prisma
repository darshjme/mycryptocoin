// ──────────────────────────────────────────────
// Crypto-to-USDT Conversion Engine
// ──────────────────────────────────────────────

/// Tracks every conversion from received crypto to USDT.
/// Full audit trail: rates, fees, tx hashes, timestamps.
model Conversion {
  id              String   @id @default(cuid())
  paymentId       String   @unique @map("payment_id") @db.VarChar(64)
  payment         Payment  @relation(fields: [paymentId], references: [id])
  merchantId      String   @map("merchant_id") @db.Uuid
  merchant        Merchant @relation(fields: [merchantId], references: [id], onDelete: Restrict)

  // What was received
  sourceCrypto    String   @map("source_crypto") @db.VarChar(20)
  sourceNetwork   String   @map("source_network") @db.VarChar(30)
  sourceAmount    Decimal  @map("source_amount") @db.Decimal(30, 18)
  sourceAddress   String   @map("source_address") @db.VarChar(255)
  sourceTxHash    String?  @map("source_tx_hash") @db.VarChar(255)

  // Exchange rate at conversion time
  exchangeRate    Decimal  @map("exchange_rate") @db.Decimal(20, 8)
  rateSource      String   @map("rate_source") @db.VarChar(50)
  rateTimestamp   DateTime @map("rate_timestamp")

  // Conversion execution
  conversionMethod  String   @map("conversion_method") @db.VarChar(50)
  conversionTxHash  String?  @map("conversion_tx_hash") @db.VarChar(255)
  conversionFee     Decimal  @map("conversion_fee") @db.Decimal(20, 8)
  conversionFeePaidBy String @default("customer") @map("conversion_fee_paid_by") @db.VarChar(20)
  slippage          Decimal? @db.Decimal(10, 4)

  // What was converted to
  targetCrypto    String   @default("USDT") @map("target_crypto") @db.VarChar(20)
  targetNetwork   String   @default("TRON") @map("target_network") @db.VarChar(30)
  grossUsdtAmount Decimal  @map("gross_usdt_amount") @db.Decimal(20, 8)
  netUsdtAmount   Decimal  @map("net_usdt_amount") @db.Decimal(20, 8)

  // Platform fee
  platformFeeRate   Decimal  @default(0.005) @map("platform_fee_rate") @db.Decimal(10, 6)
  platformFeeAmount Decimal  @map("platform_fee_amount") @db.Decimal(20, 8)
  platformFeeTxHash String?  @map("platform_fee_tx_hash") @db.VarChar(255)

  // What merchant gets
  merchantCredited  Decimal  @map("merchant_credited") @db.Decimal(20, 8)

  // Status tracking
  status          String   @default("PENDING") @db.VarChar(30)
  failureReason   String?  @map("failure_reason") @db.Text

  // Timestamps
  receivedAt      DateTime @map("received_at")
  sweepStartedAt  DateTime? @map("sweep_started_at")
  sweepTxHash     String?   @map("sweep_tx_hash") @db.VarChar(255)
  swapStartedAt   DateTime? @map("swap_started_at")
  swapCompletedAt DateTime? @map("swap_completed_at")
  settledAt       DateTime? @map("settled_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  feeDisbursements FeeDisbursement[]

  @@index([merchantId])
  @@index([merchantId, status])        // merchant conversion history
  @@index([status])
  @@index([paymentId])
  @@index([createdAt])
  @@index([status, createdAt])         // pipeline monitoring
  @@map("conversions")
}

/// Tracks exchange/DEX configurations with encrypted API keys.
model ExchangeConfig {
  id                  String  @id @default(cuid())
  name                String  @unique @db.VarChar(50)
  type                String  @db.VarChar(10) // 'cex' or 'dex'
  isActive            Boolean @default(true) @map("is_active")
  priority            Int     @default(0)
  apiKeyEncrypted     String? @map("api_key_encrypted") @db.Text // AES-256-GCM encrypted
  apiSecretEncrypted  String? @map("api_secret_encrypted") @db.Text // AES-256-GCM encrypted
  depositAddresses    Json?   @map("deposit_addresses")
  config              Json?
  maxSlippage         Decimal @default(0.5) @map("max_slippage") @db.Decimal(10, 4)
  minAmount           Decimal @default(0) @map("min_amount") @db.Decimal(20, 8)
  maxAmount           Decimal @default(1000000) @map("max_amount") @db.Decimal(20, 8)
  dailyVolume         Decimal @default(0) @map("daily_volume") @db.Decimal(20, 8)
  dailyLimit          Decimal @default(10000000) @map("daily_limit") @db.Decimal(20, 8)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([isActive, priority])        // find best active exchange
  @@map("exchange_configs")
}

/// Exchange rate history for auditing and compliance.
/// WARNING: This table grows fast. Implement retention policy (e.g. keep 90 days,
/// archive to S3/cold storage for compliance). Add partitioning by fetchedAt.
model ExchangeRateLog {
  id          String   @id @default(cuid())
  crypto      String   @db.VarChar(20)
  usdtRate    Decimal  @map("usdt_rate") @db.Decimal(20, 8)
  source      String   @db.VarChar(50)
  fetchedAt   DateTime @default(now()) @map("fetched_at")

  @@index([crypto, fetchedAt])
  @@index([fetchedAt])
  @@map("exchange_rate_logs")
}

/// Platform fee disbursements to owner wallet.
model FeeDisbursement {
  id              String   @id @default(cuid())
  conversionId    String?  @map("conversion_id")
  conversion      Conversion? @relation(fields: [conversionId], references: [id])
  merchantId      String?  @map("merchant_id") @db.Uuid
  merchant        Merchant? @relation(fields: [merchantId], references: [id], onDelete: Restrict)

  amount          Decimal  @db.Decimal(20, 8)
  ownerAddress    String   @map("owner_address") @db.VarChar(255)
  txHash          String?  @map("tx_hash") @db.VarChar(255)
  status          String   @default("PENDING") @db.VarChar(20)
  failureReason   String?  @map("failure_reason") @db.Text
  sentAt          DateTime? @map("sent_at")
  confirmedAt     DateTime? @map("confirmed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([status])
  @@index([status, createdAt])         // processing queue
  @@index([createdAt])
  @@index([merchantId])
  @@index([conversionId])
  @@map("fee_disbursements")
}

/// Hot wallet sweep records — tracks crypto movement from payment addresses to exchanges/hot wallets.
model WalletSweepRecord {
  id              String   @id @default(cuid())
  fromAddress     String   @map("from_address") @db.VarChar(255)
  toAddress       String   @map("to_address") @db.VarChar(255)
  crypto          String   @db.VarChar(20)
  network         String   @db.VarChar(30)
  amount          Decimal  @db.Decimal(30, 18)
  txHash          String?  @map("tx_hash") @db.VarChar(255)
  networkFee      Decimal? @map("network_fee") @db.Decimal(20, 8)
  status          String   @default("PENDING") @db.VarChar(20)
  purpose         String   @db.VarChar(50)
  createdAt       DateTime @default(now()) @map("created_at")
  confirmedAt     DateTime? @map("confirmed_at")

  @@index([status])
  @@index([status, createdAt])         // processing queue
  @@index([crypto])
  @@index([fromAddress])
  @@index([createdAt])
  @@map("wallet_sweep_records")
}

// ──────────────────────────────────────────────
// Invoicing
// ──────────────────────────────────────────────

/// Professional invoices with line items, tax, and crypto payment.
model Invoice {
  id              String        @id @db.VarChar(64)
  merchantId      String        @map("merchant_id") @db.Uuid
  invoiceNumber   String        @unique @map("invoice_number") @db.VarChar(50)
  status          InvoiceStatus @default(DRAFT)

  // Customer details
  customerName    String?       @map("customer_name") @db.VarChar(200)
  customerEmail   String?       @map("customer_email") @db.VarChar(255)
  customerAddress String?       @map("customer_address") @db.Text

  // Financial — ALL Decimal, NO Float
  lineItems       Json          @map("line_items")
  subtotal        Decimal       @db.Decimal(20, 8)
  taxRate         Decimal?      @map("tax_rate") @db.Decimal(10, 4)
  taxAmount       Decimal?      @map("tax_amount") @db.Decimal(20, 8)
  total           Decimal       @db.Decimal(20, 8)
  currency        String        @default("USD") @db.VarChar(10)

  // Dates
  dueDate         DateTime?     @map("due_date")
  paidAt          DateTime?     @map("paid_at")

  // Links
  paymentId       String?       @map("payment_id") @db.VarChar(64)

  notes           String?       @db.Text
  metadata        Json?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Restrict)

  @@index([merchantId])
  @@index([merchantId, status])        // listInvoices: merchantId + status filter
  @@index([merchantId, createdAt])     // listInvoices: pagination
  @@index([status])
  @@index([customerEmail])
  @@index([createdAt])
  @@map("invoices")
}

// ──────────────────────────────────────────────
// Refunds
// ──────────────────────────────────────────────

/// Refund records — full and partial refunds for completed payments. Never hard-delete.
model Refund {
  id          String       @id @db.VarChar(64)
  paymentId   String       @map("payment_id") @db.VarChar(64)
  merchantId  String       @map("merchant_id") @db.Uuid
  amount      Decimal      @db.Decimal(30, 18)
  currency    String       @db.VarChar(50) // e.g. "TRON:USDT"
  network     String?      @db.VarChar(30)
  token       String?      @db.VarChar(20)
  toAddress   String?      @map("to_address") @db.VarChar(255)
  txHash      String?      @map("tx_hash") @db.VarChar(255)
  reason      String?      @db.Text
  status      RefundStatus @default(PENDING)
  isPartial   Boolean      @default(false) @map("is_partial")
  processedAt DateTime?    @map("processed_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  payment  Payment  @relation(fields: [paymentId], references: [id])
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Restrict)

  @@index([paymentId])
  @@index([paymentId, status])         // check existing refunds
  @@index([merchantId])
  @@index([merchantId, status])
  @@index([status])
  @@index([createdAt])
  @@map("refunds")
}

// ──────────────────────────────────────────────
// Discounts / Coupons
// ──────────────────────────────────────────────

/// Discount codes: percentage or fixed amount.
model Discount {
  id                    String       @id @db.VarChar(64)
  merchantId            String       @map("merchant_id") @db.Uuid
  code                  String       @db.VarChar(50)
  type                  DiscountType
  value                 Decimal      @db.Decimal(20, 8)
  maxUses               Int?         @map("max_uses")
  usedCount             Int          @default(0) @map("used_count")
  perCustomerLimit      Int?         @map("per_customer_limit")
  minOrderAmount        Decimal?     @map("min_order_amount") @db.Decimal(20, 8)
  applicableCheckoutIds String[]     @default([]) @map("applicable_checkout_ids")
  expiresAt             DateTime?    @map("expires_at")
  isActive              Boolean      @default(true) @map("is_active")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  merchant Merchant        @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  usages   DiscountUsage[]

  @@unique([merchantId, code])         // unique code per merchant
  @@index([merchantId])
  @@index([merchantId, isActive])      // listDiscounts: active filter
  @@index([merchantId, code, isActive]) // validateDiscount
  @@index([createdAt])
  @@map("discounts")
}

/// Tracks individual discount code usages for per-customer limits.
model DiscountUsage {
  id            String    @id @db.VarChar(64)
  discountId    String    @map("discount_id") @db.VarChar(64)
  paymentId     String    @map("payment_id") @db.VarChar(64)
  customerEmail String?   @map("customer_email") @db.VarChar(255)
  appliedAt     DateTime  @default(now()) @map("applied_at")

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  @@index([discountId])
  @@index([discountId, customerEmail]) // per-customer limit check
  @@index([paymentId])
  @@map("discount_usages")
}
