// ============================================
// MyCryptoCoin — Prisma Database Schema
// PostgreSQL 15
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum UserRole {
  MERCHANT
  ADMIN
  SUPER_ADMIN
  OPERATIONS
  COMPLIANCE
  SUPPORT
  VIEWER
}

enum KycStatus {
  NOT_STARTED
  NOT_SUBMITTED
  PENDING
  PENDING_REVIEW
  UNDER_REVIEW
  VERIFIED
  APPROVED
  REJECTED
  EXPIRED
  ADDITIONAL_INFO_REQUIRED
}

enum PaymentStatus {
  PENDING
  CONFIRMING
  CONFIRMED
  COMPLETED
  EXPIRED
  CANCELLED
  FAILED
  REFUNDED
  AWAITING_PAYMENT
  UNDERPAID
  OVERPAID
  PAID
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  SWEEP
  REFUND
  FEE
}

enum TransactionStatus {
  PENDING
  CONFIRMING
  CONFIRMED
  COMPLETED
  FAILED
  EXPIRED
  CANCELLED
  REFUNDED
}

enum WithdrawalStatus {
  PENDING
  PENDING_APPROVAL
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  AUTO_APPROVED
  PARTIALLY_APPROVED
  FULLY_APPROVED
  REJECTED
  EMERGENCY_OVERRIDE
}

enum OtpPurpose {
  LOGIN
  WITHDRAWAL
  EMAIL_VERIFY
  PASSWORD_RESET
}

enum WalletType {
  HOT
  COLD
}

enum SweepStatus {
  PENDING
  COMPLETED
  FAILED
}

// ──────────────────────────────────────────────
// Core Models
// ──────────────────────────────────────────────

/// Unified merchant model — auth + business data.
/// The entire backend uses this as the primary identity.
model Merchant {
  id                      String    @id @default(uuid()) @db.Uuid
  email                   String    @unique @db.VarChar(255)
  passwordHash            String    @map("password_hash") @db.VarChar(255)
  businessName            String    @map("business_name") @db.VarChar(255)
  phone                   String?   @db.VarChar(20)
  whatsappNumber          String?   @map("whatsapp_number") @db.VarChar(20)
  country                 String?   @db.VarChar(2)
  website                 String?   @db.VarChar(512)
  logoUrl                 String?   @map("logo_url") @db.VarChar(512)
  callbackUrl             String?   @map("callback_url") @db.VarChar(512)
  role                    UserRole  @default(MERCHANT)
  isActive                Boolean   @default(false) @map("is_active")
  isEmailVerified         Boolean   @default(false) @map("is_email_verified")
  isPhoneVerified         Boolean   @default(false) @map("is_phone_verified")
  twoFactorEnabled        Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret         String?   @map("two_factor_secret") @db.VarChar(255)
  kycStatus               KycStatus @default(NOT_STARTED) @map("kyc_status")
  notificationPreferences Json?     @map("notification_preferences")
  dailyVolumeLimit        Decimal   @default(10000) @map("daily_volume_limit") @db.Decimal(20, 8)
  monthlyVolumeLimit      Decimal   @default(100000) @map("monthly_volume_limit") @db.Decimal(20, 8)

  // KYC / Compliance tier fields
  kycTier                 Int       @default(0) @map("kyc_tier")
  kycExpiresAt            DateTime? @map("kyc_expires_at")

  // Freeze fields (emergency & fraud)
  isFrozen                Boolean   @default(false) @map("is_frozen")
  frozenAt                DateTime? @map("frozen_at")
  frozenBy                String?   @map("frozen_by") @db.Uuid
  frozenReason            String?   @map("frozen_reason") @db.Text

  lastLoginAt             DateTime? @map("last_login_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  apiKeys          ApiKey[]
  wallets          Wallet[]
  payments         Payment[]
  withdrawals      Withdrawal[]
  webhooks         Webhook[]
  whatsappSessions WhatsAppSession[]
  feeRecords       FeeRecord[]
  auditLogs        AuditLog[]
  fraudAlerts      FraudAlert[]
  kycSubmissions   KycSubmission[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([isActive])
  @@index([isFrozen])
  @@index([kycTier])
  @@map("merchants")
}

model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  merchantId  String    @map("merchant_id") @db.Uuid
  name        String    @db.VarChar(100)
  keyHash     String    @map("key_hash") @db.VarChar(255)
  keyPrefix   String    @map("key_prefix") @db.VarChar(16)
  mode        String    @db.VarChar(10) // 'live' | 'test'
  permissions String[]  @default(["payments:read", "payments:write"])
  ipWhitelist String[]  @default([]) @map("ip_whitelist")
  isActive    Boolean   @default(true) @map("is_active")
  revokedAt   DateTime? @map("revoked_at")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([keyPrefix])
  @@index([keyHash])
  @@map("api_keys")
}

model Wallet {
  id                    String   @id @default(uuid()) @db.Uuid
  merchantId            String   @map("merchant_id") @db.Uuid
  crypto                String   @db.VarChar(20)
  address               String   @db.VarChar(255)
  publicKey             String?  @map("public_key") @db.VarChar(255)
  derivationPath        String?  @map("derivation_path") @db.VarChar(100)
  derivationIndex       Int?     @map("derivation_index")
  balance               Decimal  @default(0) @db.Decimal(30, 18)
  pendingBalance        Decimal  @default(0) @map("pending_balance") @db.Decimal(30, 18)
  totalReceived         Decimal  @default(0) @map("total_received") @db.Decimal(30, 18)
  totalWithdrawn        Decimal  @default(0) @map("total_withdrawn") @db.Decimal(30, 18)
  autoWithdrawEnabled   Boolean  @default(false) @map("auto_withdraw_enabled")
  autoWithdrawAddress   String?  @map("auto_withdraw_address") @db.VarChar(255)
  autoWithdrawThreshold Decimal? @map("auto_withdraw_threshold") @db.Decimal(30, 18)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  merchant    Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  payments    Payment[]
  withdrawals Withdrawal[]

  @@unique([merchantId, crypto])
  @@index([merchantId])
  @@index([crypto])
  @@map("wallets")
}

model Payment {
  id                    String        @id @db.VarChar(64)
  merchantId            String        @map("merchant_id") @db.Uuid
  walletId              String?       @map("wallet_id") @db.Uuid
  crypto                String        @db.VarChar(20)
  amount                Decimal       @db.Decimal(30, 18)
  currency              String        @default("USD") @db.VarChar(10)
  description           String?       @db.VarChar(500)
  orderId               String?       @map("order_id") @db.VarChar(100)
  customerEmail         String?       @map("customer_email") @db.VarChar(255)
  customerName          String?       @map("customer_name") @db.VarChar(200)
  callbackUrl           String?       @map("callback_url") @db.VarChar(512)
  redirectUrl           String?       @map("redirect_url") @db.VarChar(512)
  depositAddress        String        @map("deposit_address") @db.VarChar(255)
  derivationPath        String?       @map("derivation_path") @db.VarChar(100)
  txHash                String?       @map("tx_hash") @db.VarChar(255)
  confirmations         Int           @default(0)
  confirmationsRequired Int           @map("confirmations_required")
  detectedAmount        Decimal?      @map("detected_amount") @db.Decimal(30, 18)
  feeAmount             Decimal?      @map("fee_amount") @db.Decimal(30, 18)
  netAmount             Decimal?      @map("net_amount") @db.Decimal(30, 18)
  status                PaymentStatus @default(PENDING)
  metadata              Json?
  expiresAt             DateTime      @map("expires_at")
  completedAt           DateTime?     @map("completed_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  merchant  Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  wallet    Wallet?    @relation(fields: [walletId], references: [id])
  feeRecord FeeRecord?

  @@index([merchantId])
  @@index([orderId])
  @@index([status])
  @@index([depositAddress])
  @@index([crypto])
  @@index([createdAt])
  @@map("payments")
}

model Withdrawal {
  id              String           @id @db.VarChar(64)
  merchantId      String           @map("merchant_id") @db.Uuid
  walletId        String           @map("wallet_id") @db.Uuid
  crypto          String           @db.VarChar(20)
  amount          Decimal          @db.Decimal(30, 18)
  toAddress       String           @map("to_address") @db.VarChar(255)
  memo            String?          @db.VarChar(255)
  estimatedFee    Decimal?         @map("estimated_fee") @db.Decimal(30, 18)
  networkFee      Decimal?         @map("network_fee") @db.Decimal(30, 18)
  txHash          String?          @map("tx_hash") @db.VarChar(255)
  status          WithdrawalStatus @default(PENDING)
  type            String           @default("manual") @db.VarChar(20)
  error           String?          @db.Text
  completedAt     DateTime?        @map("completed_at")

  // Multi-sig approval fields
  approvalStatus    ApprovalStatus? @map("approval_status")
  requiredApprovals Int?            @map("required_approvals")
  currentApprovals  Int?            @default(0) @map("current_approvals")
  coolingEndsAt     DateTime?       @map("cooling_ends_at")
  approvedAt        DateTime?       @map("approved_at")
  rejectedAt        DateTime?       @map("rejected_at")
  rejectionReason   String?         @map("rejection_reason") @db.Text
  amountUsd         Decimal?        @map("amount_usd") @db.Decimal(20, 8)

  reviewedBy      String?          @map("reviewed_by") @db.Uuid
  reviewNote      String?          @map("review_note") @db.Text

  processedAt     DateTime?        @map("processed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  merchant            Merchant             @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  wallet              Wallet               @relation(fields: [walletId], references: [id])
  withdrawalApprovals WithdrawalApproval[]

  @@index([merchantId])
  @@index([walletId])
  @@index([status])
  @@index([approvalStatus])
  @@index([crypto])
  @@index([createdAt])
  @@map("withdrawals")
}

model WhatsAppSession {
  id           String    @id @default(uuid()) @db.Uuid
  merchantId   String    @map("merchant_id") @db.Uuid
  phoneNumber  String    @map("phone_number") @db.VarChar(20)
  sessionData  Json?     @map("session_data")
  isConnected  Boolean   @default(false) @map("is_connected")
  lastActiveAt DateTime? @map("last_active_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, phoneNumber])
  @@index([merchantId])
  @@map("whatsapp_sessions")
}

model OtpCode {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  code      String     @db.VarChar(10)
  purpose   OtpPurpose
  isUsed    Boolean    @default(false) @map("is_used")
  expiresAt DateTime   @map("expires_at")
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([userId])
  @@index([code, purpose])
  @@index([expiresAt])
  @@map("otp_codes")
}

/// Webhook endpoint registered by a merchant.
model Webhook {
  id              String            @id @default(uuid()) @db.Uuid
  merchantId      String            @map("merchant_id") @db.Uuid
  url             String            @db.VarChar(512)
  secret          String            @db.VarChar(255)
  events          String[]          @default(["payment.completed"])
  isActive        Boolean           @default(true) @map("is_active")
  failureCount    Int               @default(0) @map("failure_count")
  lastDeliveredAt DateTime?         @map("last_delivered_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  merchant   Merchant          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([merchantId])
  @@map("webhooks")
}

/// Log of individual webhook delivery attempts.
model WebhookDelivery {
  id         String   @id @default(uuid()) @db.Uuid
  webhookId  String   @map("webhook_id") @db.Uuid
  event      String   @db.VarChar(100)
  payload    Json
  statusCode Int      @map("status_code")
  success    Boolean
  attempt    Int      @default(1)
  error      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([event])
  @@index([createdAt])
  @@map("webhook_deliveries")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  merchantId    String?  @map("merchant_id") @db.Uuid
  adminId       String?  @map("admin_id") @db.VarChar(255)
  adminEmail    String?  @map("admin_email") @db.VarChar(255)
  action        String   @db.VarChar(100)
  resource      String?  @db.VarChar(100)
  resourceId    String?  @map("resource_id") @db.VarChar(100)
  target        String?  @db.VarChar(255)
  targetId      String?  @map("target_id") @db.VarChar(255)
  previousValue String?  @map("previous_value") @db.Text
  newValue      String?  @map("new_value") @db.Text
  ipAddress     String   @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent") @db.VarChar(512)
  details       Json?
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  merchant Merchant? @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model FeeRecord {
  id          String    @id @default(uuid()) @db.Uuid
  paymentId   String    @unique @map("payment_id") @db.VarChar(64)
  merchantId  String    @map("merchant_id") @db.Uuid
  crypto      String    @db.VarChar(20)
  grossAmount Decimal   @map("gross_amount") @db.Decimal(30, 18)
  feeAmount   Decimal   @map("fee_amount") @db.Decimal(30, 18)
  netAmount   Decimal   @map("net_amount") @db.Decimal(30, 18)
  settledAt   DateTime? @map("settled_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  payment  Payment  @relation(fields: [paymentId], references: [id])
  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@index([crypto])
  @@index([createdAt])
  @@index([settledAt])
  @@map("fee_records")
}

// ──────────────────────────────────────────────
// Multi-Sig Withdrawal Approval
// ──────────────────────────────────────────────

model WithdrawalApproval {
  id           String   @id @default(uuid()) @db.Uuid
  withdrawalId String   @map("withdrawal_id") @db.VarChar(64)
  adminId      String   @map("admin_id") @db.VarChar(255)
  adminEmail   String   @map("admin_email") @db.VarChar(255)
  adminRole    String   @map("admin_role") @db.VarChar(50)
  action       String   @db.VarChar(20)
  comment      String   @default("") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  withdrawal Withdrawal @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)

  @@index([withdrawalId])
  @@index([adminId])
  @@index([createdAt])
  @@map("withdrawal_approvals")
}

// ──────────────────────────────────────────────
// Platform Wallets (Hot/Cold) & Sweeps
// ──────────────────────────────────────────────

model PlatformWallet {
  id          String     @id @default(uuid()) @db.Uuid
  crypto      String     @db.VarChar(20)
  type        WalletType
  address     String     @db.VarChar(255)
  balance     Decimal    @default(0) @db.Decimal(30, 18)
  label       String?    @db.VarChar(100)
  lastSweepAt DateTime?  @map("last_sweep_at")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@unique([crypto, type])
  @@index([crypto])
  @@index([type])
  @@map("platform_wallets")
}

model WalletSweep {
  id          String      @id @default(uuid()) @db.Uuid
  crypto      String      @db.VarChar(20)
  fromType    String      @map("from_type") @db.VarChar(10)
  toType      String      @map("to_type") @db.VarChar(10)
  amount      Decimal     @db.Decimal(30, 18)
  txHash      String      @map("tx_hash") @db.VarChar(255)
  initiatedBy String      @map("initiated_by") @db.VarChar(255)
  status      SweepStatus @default(PENDING)
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([crypto])
  @@index([status])
  @@index([createdAt])
  @@map("wallet_sweeps")
}

// ──────────────────────────────────────────────
// Reconciliation
// ──────────────────────────────────────────────

model ReconciliationReport {
  id                  String   @id @default(uuid()) @db.Uuid
  runBy               String   @map("run_by") @db.VarChar(255)
  type                String   @db.VarChar(20)
  results             Json
  overallStatus       String   @map("overall_status") @db.VarChar(30)
  totalDiscrepancyUsd Decimal? @default(0) @map("total_discrepancy_usd") @db.Decimal(20, 8)
  duration            Int
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([overallStatus])
  @@index([createdAt])
  @@map("reconciliation_reports")
}

// ──────────────────────────────────────────────
// System Settings
// ──────────────────────────────────────────────

model SystemSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(255)
  value     String   @db.Text
  updatedBy String?  @map("updated_by") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@map("system_settings")
}

// ──────────────────────────────────────────────
// Fraud Detection & Address Blacklist
// ──────────────────────────────────────────────

model FraudAlert {
  id                String    @id @default(uuid()) @db.Uuid
  merchantId        String    @map("merchant_id") @db.Uuid
  type              String    @db.VarChar(50)
  severity          String    @db.VarChar(20)
  status            String    @default("active") @db.VarChar(30)
  title             String    @db.VarChar(255)
  description       String    @db.Text
  metadata          Json?
  recommendedAction String?   @map("recommended_action") @db.Text
  autoFrozen        Boolean   @default(false) @map("auto_frozen")
  notes             String?   @db.Text
  acknowledgedAt    DateTime? @map("acknowledged_at")
  acknowledgedBy    String?   @map("acknowledged_by") @db.VarChar(255)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([status])
  @@index([severity])
  @@index([type])
  @@index([createdAt])
  @@map("fraud_alerts")
}

model AddressBlacklist {
  id        String   @id @default(uuid()) @db.Uuid
  address   String   @unique @db.VarChar(255)
  reason    String?  @db.Text
  source    String?  @db.VarChar(100)
  addedBy   String?  @map("added_by") @db.VarChar(255)
  updatedBy String?  @map("updated_by") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([address])
  @@map("address_blacklist")
}

// ──────────────────────────────────────────────
// KYC / Compliance
// ──────────────────────────────────────────────

model KycSubmission {
  id              String    @id @default(uuid()) @db.Uuid
  merchantId      String    @map("merchant_id") @db.Uuid
  requestedTier   Int       @map("requested_tier")
  status          String    @default("pending_review") @db.VarChar(50)
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?   @map("reviewed_by") @db.VarChar(255)
  reviewNotes     String?   @map("review_notes") @db.Text
  rejectionReason String?   @map("rejection_reason") @db.Text
  expiresAt       DateTime? @map("expires_at")
  submittedAt     DateTime  @default(now()) @map("submitted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  merchant  Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  documents KycDocument[]

  @@index([merchantId])
  @@index([status])
  @@index([submittedAt])
  @@map("kyc_submissions")
}

model KycDocument {
  id           String    @id @default(uuid()) @db.Uuid
  submissionId String    @map("submission_id") @db.Uuid
  type         String    @db.VarChar(50)
  fileName     String    @map("file_name") @db.VarChar(255)
  fileUrl      String    @map("file_url") @db.VarChar(512)
  verified     Boolean   @default(false)
  verifiedAt   DateTime? @map("verified_at")
  verifiedBy   String?   @map("verified_by") @db.VarChar(255)
  uploadedAt   DateTime  @default(now()) @map("uploaded_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  submission KycSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([type])
  @@map("kyc_documents")
}

// ──────────────────────────────────────────────
// Admin Security
// ──────────────────────────────────────────────

model AdminSession {
  id           String   @id @default(uuid()) @db.Uuid
  adminId      String   @map("admin_id") @db.VarChar(255)
  adminEmail   String   @map("admin_email") @db.VarChar(255)
  adminRole    String   @map("admin_role") @db.VarChar(50)
  ipAddress    String   @map("ip_address") @db.VarChar(45)
  userAgent    String   @map("user_agent") @db.VarChar(512)
  device       String?  @db.VarChar(50)
  location     String?  @db.VarChar(255)
  isActive     Boolean  @default(true) @map("is_active")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([isActive])
  @@index([expiresAt])
  @@map("admin_sessions")
}

model AdminLoginLog {
  id            String   @id @default(uuid()) @db.Uuid
  adminId       String?  @map("admin_id") @db.VarChar(255)
  email         String   @db.VarChar(255)
  ipAddress     String   @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent") @db.VarChar(512)
  success       Boolean
  failureReason String?  @map("failure_reason") @db.Text
  country       String?  @db.VarChar(100)
  city          String?  @db.VarChar(100)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([adminId])
  @@index([success])
  @@index([createdAt])
  @@map("admin_login_logs")
}

model IpWhitelist {
  id        String   @id @default(uuid()) @db.Uuid
  adminId   String   @map("admin_id") @db.Uuid
  ipAddress String   @map("ip_address") @db.VarChar(45)
  label     String?  @db.VarChar(100)
  addedBy   String   @map("added_by") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([adminId, ipAddress])
  @@index([adminId])
  @@map("ip_whitelist")
}
