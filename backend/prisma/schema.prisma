  addedBy   String?  @map("added_by") @db.VarChar(255)
  updatedBy String?  @map("updated_by") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("address_blacklist")
}

// ──────────────────────────────────────────────
