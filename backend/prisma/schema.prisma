// ============================================
// MyCryptoCoin — Prisma Database Schema
// PostgreSQL 15
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum UserRole {
  MERCHANT
  ADMIN
  SUPER_ADMIN
  OPERATIONS
  COMPLIANCE
  SUPPORT
  VIEWER
}

enum KycStatus {
  NOT_STARTED
  NOT_SUBMITTED
  PENDING
  PENDING_REVIEW
  UNDER_REVIEW
  VERIFIED
  APPROVED
  REJECTED
  EXPIRED
  ADDITIONAL_INFO_REQUIRED
}

enum CryptoNetwork {
  BITCOIN
  ETHEREUM
  SOLANA
  TRON
  LITECOIN
  BSC
  POLYGON
  DOGECOIN
  XRPL
}

enum TokenSymbol {
  BTC
  ETH
  SOL
  LTC
  USDT
  USDC
  TRX
  BNB
  MATIC
  DOGE
  XRP
  USDT_ERC20
  USDT_TRC20
}

enum PaymentStatus {
  AWAITING_PAYMENT
  UNDERPAID
  PAID
  OVERPAID
  EXPIRED
  CANCELLED
  REFUNDED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  SWEEP
  REFUND
  FEE
}

enum TransactionStatus {
  PENDING
  CONFIRMING
  CONFIRMED
  COMPLETED
  FAILED
  EXPIRED
  CANCELLED
  REFUNDED
}

enum WithdrawalStatus {
  PENDING
  PENDING_APPROVAL
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  AUTO_APPROVED
  PARTIALLY_APPROVED
  FULLY_APPROVED
  REJECTED
  EMERGENCY_OVERRIDE
}

enum OtpPurpose {
  LOGIN
  WITHDRAWAL
  EMAIL_VERIFY
  PASSWORD_RESET
}

enum WalletType {
  HOT
  COLD
}

enum SweepStatus {
  PENDING
  COMPLETED
  FAILED
}

// ──────────────────────────────────────────────
// Core Models (original 14 + security/compliance)
// ──────────────────────────────────────────────

model User {
  id               String    @id @default(uuid()) @db.Uuid
  email            String    @unique @db.VarChar(255)
  passwordHash     String    @map("password_hash") @db.VarChar(255)
  role             UserRole  @default(MERCHANT)
  isEmailVerified  Boolean   @default(false) @map("is_email_verified")
  twoFactorEnabled Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?   @map("two_factor_secret") @db.VarChar(255)
  kycStatus        KycStatus @default(NOT_STARTED) @map("kyc_status")
  lastLoginAt      DateTime? @map("last_login_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  merchant    Merchant?
  otpCodes    OtpCode[]
  auditLogs   AuditLog[]    @relation("UserAuditLogs")
  ipWhitelist IpWhitelist[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Merchant {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @unique @map("user_id") @db.Uuid
  email              String?   @db.VarChar(255)
  businessName       String    @map("business_name") @db.VarChar(255)
  businessUrl        String?   @map("business_url") @db.VarChar(512)
  logoUrl            String?   @map("logo_url") @db.VarChar(512)
  callbackUrl        String?   @map("callback_url") @db.VarChar(512)
  webhookSecret      String    @map("webhook_secret") @db.VarChar(255)
  isActive           Boolean   @default(true) @map("is_active")
  dailyVolumeLimit   Decimal   @default(10000) @map("daily_volume_limit") @db.Decimal(20, 8)
  monthlyVolumeLimit Decimal   @default(100000) @map("monthly_volume_limit") @db.Decimal(20, 8)

  // KYC / Compliance tier fields
  kycTier            Int       @default(0) @map("kyc_tier")
  kycStatus          String?   @map("merchant_kyc_status") @db.VarChar(50)
  kycExpiresAt       DateTime? @map("kyc_expires_at")

  // Freeze fields (emergency & fraud)
  isFrozen           Boolean   @default(false) @map("is_frozen")
  frozenAt           DateTime? @map("frozen_at")
  frozenBy           String?   @map("frozen_by") @db.Uuid
  frozenReason       String?   @map("frozen_reason") @db.Text

  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeys           ApiKey[]
  wallets           Wallet[]
  payments          Payment[]
  withdrawals       Withdrawal[]
  whatsappSessions  WhatsAppSession[]
  webhookEndpoints  WebhookEndpoint[]
  feeRecords        FeeRecord[]
  auditLogs         AuditLog[]         @relation("MerchantAuditLogs")
  fraudAlerts       FraudAlert[]
  kycSubmissions    KycSubmission[]

  @@index([userId])
  @@index([isActive])
  @@index([isFrozen])
  @@index([kycTier])
  @@index([kycExpiresAt])
  @@map("merchants")
}

model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  merchantId  String    @map("merchant_id") @db.Uuid
  keyHash     String    @map("key_hash") @db.VarChar(255)
  label       String    @db.VarChar(100)
  prefix      String    @db.VarChar(16)
  permissions String[]  @default(["payments:read", "payments:write"])
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([prefix])
  @@index([keyHash])
  @@map("api_keys")
}

model Wallet {
  id             String        @id @default(uuid()) @db.Uuid
  merchantId     String        @map("merchant_id") @db.Uuid
  network        CryptoNetwork
  token          TokenSymbol
  crypto         String        @default("") @db.VarChar(20)
  balance        Decimal       @default(0) @db.Decimal(30, 18)
  pendingBalance Decimal       @default(0) @map("pending_balance") @db.Decimal(30, 18)
  totalReceived  Decimal       @default(0) @map("total_received") @db.Decimal(30, 18)
  totalWithdrawn Decimal       @default(0) @map("total_withdrawn") @db.Decimal(30, 18)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  merchant       Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  addresses      CryptoAddress[]
  transactions   Transaction[]
  withdrawals    Withdrawal[]

  @@unique([merchantId, network, token])
  @@index([merchantId])
  @@index([crypto])
  @@map("wallets")
}

model CryptoAddress {
  id              String        @id @default(uuid()) @db.Uuid
  walletId        String        @map("wallet_id") @db.Uuid
  paymentId       String?       @map("payment_id") @db.Uuid
  network         CryptoNetwork
  address         String        @db.VarChar(255)
  derivationPath  String?       @map("derivation_path") @db.VarChar(100)
  derivationIndex Int?          @map("derivation_index")
  isUsed          Boolean       @default(false) @map("is_used")
  createdAt       DateTime      @default(now()) @map("created_at")

  wallet  Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@unique([network, address])
  @@index([walletId])
  @@index([paymentId])
  @@index([address])
  @@map("crypto_addresses")
}

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  merchantId        String        @map("merchant_id") @db.Uuid
  externalId        String?       @map("external_id") @db.VarChar(255)
  network           CryptoNetwork
  token             TokenSymbol
  requestedAmount   Decimal       @map("requested_amount") @db.Decimal(20, 8)
  requestedCurrency String        @default("USD") @map("requested_currency") @db.VarChar(10)
  cryptoAmount      Decimal       @map("crypto_amount") @db.Decimal(30, 18)
  receivedAmount    Decimal       @default(0) @map("received_amount") @db.Decimal(30, 18)
  exchangeRate      Decimal       @map("exchange_rate") @db.Decimal(20, 8)
  fee               Decimal       @default(0) @db.Decimal(30, 18)
  feeRate           Decimal       @default(0.005) @map("fee_rate") @db.Decimal(10, 6)
  status            PaymentStatus @default(AWAITING_PAYMENT)
  depositAddress    String        @map("deposit_address") @db.VarChar(255)
  customerEmail     String?       @map("customer_email") @db.VarChar(255)
  metadata          Json?
  callbackUrl       String?       @map("callback_url") @db.VarChar(512)
  expiresAt         DateTime      @map("expires_at")
  paidAt            DateTime?     @map("paid_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  merchant      Merchant        @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  addresses     CryptoAddress[]
  transactions  Transaction[]
  feeRecord     FeeRecord?

  @@index([merchantId])
  @@index([externalId])
  @@index([status])
  @@index([depositAddress])
  @@index([createdAt])
  @@map("payments")
}

model Transaction {
  id                    String            @id @default(uuid()) @db.Uuid
  paymentId             String?           @map("payment_id") @db.Uuid
  withdrawalId          String?           @map("withdrawal_id") @db.Uuid
  walletId              String            @map("wallet_id") @db.Uuid
  network               CryptoNetwork
  token                 TokenSymbol
  type                  TransactionType?
  txHash                String            @map("tx_hash") @db.VarChar(255)
  fromAddress           String            @map("from_address") @db.VarChar(255)
  toAddress             String            @map("to_address") @db.VarChar(255)
  amount                Decimal           @db.Decimal(30, 18)
  fee                   Decimal           @default(0) @db.Decimal(30, 18)
  confirmations         Int               @default(0)
  requiredConfirmations Int               @map("required_confirmations")
  status                TransactionStatus @default(PENDING)
  blockNumber           BigInt?           @map("block_number")
  blockHash             String?           @map("block_hash") @db.VarChar(255)
  rawData               Json?             @map("raw_data")
  confirmedAt           DateTime?         @map("confirmed_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  payment    Payment?    @relation(fields: [paymentId], references: [id])
  withdrawal Withdrawal? @relation(fields: [withdrawalId], references: [id])
  wallet     Wallet      @relation(fields: [walletId], references: [id])

  @@unique([network, txHash])
  @@index([paymentId])
  @@index([withdrawalId])
  @@index([walletId])
  @@index([txHash])
  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

model Withdrawal {
  id                  String           @id @default(uuid()) @db.Uuid
  merchantId          String           @map("merchant_id") @db.Uuid
  walletId            String           @map("wallet_id") @db.Uuid
  network             CryptoNetwork
  token               TokenSymbol
  crypto              String           @default("") @db.VarChar(20)
  amount              Decimal          @db.Decimal(30, 18)
  amountUsd           Decimal?         @map("amount_usd") @db.Decimal(20, 8)
  fee                 Decimal          @default(0) @db.Decimal(30, 18)
  estimatedFee        Decimal?         @map("estimated_fee") @db.Decimal(30, 18)
  netAmount           Decimal          @map("net_amount") @db.Decimal(30, 18)
  toAddress           String           @map("to_address") @db.VarChar(255)
  memo                String?          @db.VarChar(255)
  txHash              String?          @map("tx_hash") @db.VarChar(255)
  type                String           @default("manual") @db.VarChar(20)
  status              WithdrawalStatus @default(PENDING)

  // Multi-sig approval fields
  approvalStatus      ApprovalStatus?  @map("approval_status")
  requiredApprovals   Int?             @map("required_approvals")
  currentApprovals    Int?             @default(0) @map("current_approvals")
  coolingEndsAt       DateTime?        @map("cooling_ends_at")
  approvedAt          DateTime?        @map("approved_at")
  rejectedAt          DateTime?        @map("rejected_at")
  rejectionReason     String?          @map("rejection_reason") @db.Text

  // Legacy review fields
  reviewedBy          String?          @map("reviewed_by") @db.Uuid
  reviewNote          String?          @map("review_note") @db.Text

  processedAt         DateTime?        @map("processed_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  merchant              Merchant              @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  wallet                Wallet                @relation(fields: [walletId], references: [id])
  transactions          Transaction[]
  withdrawalApprovals   WithdrawalApproval[]

  @@index([merchantId])
  @@index([walletId])
  @@index([status])
  @@index([approvalStatus])
  @@index([crypto])
  @@index([createdAt])
  @@map("withdrawals")
}

model WhatsAppSession {
  id           String   @id @default(uuid()) @db.Uuid
  merchantId   String   @map("merchant_id") @db.Uuid
  phoneNumber  String   @map("phone_number") @db.VarChar(20)
  sessionData  Json?    @map("session_data")
  isConnected  Boolean  @default(false) @map("is_connected")
  lastActiveAt DateTime? @map("last_active_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, phoneNumber])
  @@index([merchantId])
  @@map("whatsapp_sessions")
}

model OtpCode {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  code      String     @db.VarChar(10)
  purpose   OtpPurpose
  isUsed    Boolean    @default(false) @map("is_used")
  expiresAt DateTime   @map("expires_at")
  createdAt DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code, purpose])
  @@index([expiresAt])
  @@map("otp_codes")
}

model WebhookEndpoint {
  id         String   @id @default(uuid()) @db.Uuid
  merchantId String   @map("merchant_id") @db.Uuid
  url        String   @db.VarChar(512)
  secret     String   @db.VarChar(255)
  events     String[] @default(["payment.completed"])
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  merchant Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  logs     WebhookLog[]

  @@index([merchantId])
  @@map("webhook_endpoints")
}

model WebhookLog {
  id             String    @id @default(uuid()) @db.Uuid
  endpointId     String    @map("endpoint_id") @db.Uuid
  event          String    @db.VarChar(100)
  payload        Json
  responseStatus Int?      @map("response_status")
  responseBody   String?   @map("response_body") @db.Text
  attempts       Int       @default(1)
  nextRetryAt    DateTime? @map("next_retry_at")
  deliveredAt    DateTime? @map("delivered_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([event])
  @@index([createdAt])
  @@map("webhook_logs")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  merchantId    String?  @map("merchant_id") @db.Uuid
  adminId       String?  @map("admin_id") @db.VarChar(255)
  adminEmail    String?  @map("admin_email") @db.VarChar(255)
  action        String   @db.VarChar(100)
  resource      String?  @db.VarChar(100)
  resourceId    String?  @map("resource_id") @db.VarChar(100)
  target        String?  @db.VarChar(255)
  targetId      String?  @map("target_id") @db.VarChar(255)
  previousValue String?  @map("previous_value") @db.Text
  newValue      String?  @map("new_value") @db.Text
  ipAddress     String   @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent") @db.VarChar(512)
  details       Json?
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  user     User?     @relation("UserAuditLogs", fields: [userId], references: [id])
  merchant Merchant? @relation("MerchantAuditLogs", fields: [merchantId], references: [id])

  @@index([userId])
  @@index([merchantId])
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model FeeRecord {
  id          String        @id @default(uuid()) @db.Uuid
  paymentId   String        @unique @map("payment_id") @db.Uuid
  merchantId  String        @map("merchant_id") @db.Uuid
  network     CryptoNetwork
  token       TokenSymbol
  grossAmount Decimal       @map("gross_amount") @db.Decimal(30, 18)
  feeRate     Decimal       @map("fee_rate") @db.Decimal(10, 6)
  feeAmount   Decimal       @map("fee_amount") @db.Decimal(30, 18)
  netAmount   Decimal       @map("net_amount") @db.Decimal(30, 18)
  settledAt   DateTime?     @map("settled_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  payment  Payment  @relation(fields: [paymentId], references: [id])
  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@index([createdAt])
  @@index([settledAt])
  @@map("fee_records")
}

// ──────────────────────────────────────────────
// Multi-Sig Withdrawal Approval
// ──────────────────────────────────────────────

model WithdrawalApproval {
  id           String   @id @default(uuid()) @db.Uuid
  withdrawalId String   @map("withdrawal_id") @db.Uuid
  adminId      String   @map("admin_id") @db.VarChar(255)
  adminEmail   String   @map("admin_email") @db.VarChar(255)
  adminRole    String   @map("admin_role") @db.VarChar(50)
  action       String   @db.VarChar(20) // APPROVED | REJECTED
  comment      String   @default("") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  withdrawal Withdrawal @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)

  @@index([withdrawalId])
  @@index([adminId])
  @@index([createdAt])
  @@map("withdrawal_approvals")
}

// ──────────────────────────────────────────────
// Platform Wallets (Hot/Cold) & Sweeps
// ──────────────────────────────────────────────

model PlatformWallet {
  id          String     @id @default(uuid()) @db.Uuid
  crypto      String     @db.VarChar(20)
  type        WalletType
  address     String     @db.VarChar(255)
  balance     Decimal    @default(0) @db.Decimal(30, 18)
  label       String?    @db.VarChar(100)
  lastSweepAt DateTime?  @map("last_sweep_at")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@unique([crypto, type])
  @@index([crypto])
  @@index([type])
  @@map("platform_wallets")
}

model WalletSweep {
  id          String      @id @default(uuid()) @db.Uuid
  crypto      String      @db.VarChar(20)
  fromType    String      @map("from_type") @db.VarChar(10) // HOT | COLD
  toType      String      @map("to_type") @db.VarChar(10)   // HOT | COLD
  amount      Decimal     @db.Decimal(30, 18)
  txHash      String      @map("tx_hash") @db.VarChar(255)
  initiatedBy String      @map("initiated_by") @db.VarChar(255)
  status      SweepStatus @default(PENDING)
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([crypto])
  @@index([status])
  @@index([createdAt])
  @@map("wallet_sweeps")
}

// ──────────────────────────────────────────────
// Reconciliation
// ──────────────────────────────────────────────

model ReconciliationReport {
  id                  String   @id @default(uuid()) @db.Uuid
  runBy               String   @map("run_by") @db.VarChar(255)
  type                String   @db.VarChar(20) // manual | scheduled
  results             Json
  overallStatus       String   @map("overall_status") @db.VarChar(30)
  totalDiscrepancyUsd Decimal? @default(0) @map("total_discrepancy_usd") @db.Decimal(20, 8)
  duration            Int      // milliseconds
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([overallStatus])
  @@index([createdAt])
  @@map("reconciliation_reports")
}

// ──────────────────────────────────────────────
// System Settings (key-value config store)
// ──────────────────────────────────────────────

model SystemSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(255)
  value     String   @db.Text
  updatedBy String?  @map("updated_by") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@map("system_settings")
}

// ──────────────────────────────────────────────
// Fraud Detection & Address Blacklist
// ──────────────────────────────────────────────

model FraudAlert {
  id                String   @id @default(uuid()) @db.Uuid
  merchantId        String   @map("merchant_id") @db.Uuid
  type              String   @db.VarChar(50)
  severity          String   @db.VarChar(20)
  status            String   @default("active") @db.VarChar(30)
  title             String   @db.VarChar(255)
  description       String   @db.Text
  metadata          Json?
  recommendedAction String?  @map("recommended_action") @db.Text
  autoFrozen        Boolean  @default(false) @map("auto_frozen")
  notes             String?  @db.Text
  acknowledgedAt    DateTime? @map("acknowledged_at")
  acknowledgedBy    String?  @map("acknowledged_by") @db.VarChar(255)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([status])
  @@index([severity])
  @@index([type])
  @@index([createdAt])
  @@map("fraud_alerts")
}

model AddressBlacklist {
  id        String   @id @default(uuid()) @db.Uuid
  address   String   @unique @db.VarChar(255)
  reason    String?  @db.Text
  source    String?  @db.VarChar(100)
  addedBy   String?  @map("added_by") @db.VarChar(255)
  updatedBy String?  @map("updated_by") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([address])
  @@map("address_blacklist")
}

// ──────────────────────────────────────────────
// KYC / Compliance
// ──────────────────────────────────────────────

model KycSubmission {
  id              String    @id @default(uuid()) @db.Uuid
  merchantId      String    @map("merchant_id") @db.Uuid
  requestedTier   Int       @map("requested_tier")
  status          String    @default("pending_review") @db.VarChar(50)
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?   @map("reviewed_by") @db.VarChar(255)
  reviewNotes     String?   @map("review_notes") @db.Text
  rejectionReason String?   @map("rejection_reason") @db.Text
  expiresAt       DateTime? @map("expires_at")
  submittedAt     DateTime  @default(now()) @map("submitted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  merchant  Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  documents KycDocument[]

  @@index([merchantId])
  @@index([status])
  @@index([submittedAt])
  @@map("kyc_submissions")
}

model KycDocument {
  id           String    @id @default(uuid()) @db.Uuid
  submissionId String    @map("submission_id") @db.Uuid
  type         String    @db.VarChar(50)
  fileName     String    @map("file_name") @db.VarChar(255)
  fileUrl      String    @map("file_url") @db.VarChar(512)
  verified     Boolean   @default(false)
  verifiedAt   DateTime? @map("verified_at")
  verifiedBy   String?   @map("verified_by") @db.VarChar(255)
  uploadedAt   DateTime  @default(now()) @map("uploaded_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  submission KycSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([type])
  @@map("kyc_documents")
}

// ──────────────────────────────────────────────
// Admin Security: Sessions, Login Logs, IP Whitelist
// ──────────────────────────────────────────────

model AdminSession {
  id           String   @id @default(uuid()) @db.Uuid
  adminId      String   @map("admin_id") @db.VarChar(255)
  adminEmail   String   @map("admin_email") @db.VarChar(255)
  adminRole    String   @map("admin_role") @db.VarChar(50)
  ipAddress    String   @map("ip_address") @db.VarChar(45)
  userAgent    String   @map("user_agent") @db.VarChar(512)
  device       String?  @db.VarChar(50)
  location     String?  @db.VarChar(255)
  isActive     Boolean  @default(true) @map("is_active")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([isActive])
  @@index([expiresAt])
  @@map("admin_sessions")
}

model AdminLoginLog {
  id            String   @id @default(uuid()) @db.Uuid
  adminId       String?  @map("admin_id") @db.VarChar(255)
  email         String   @db.VarChar(255)
  ipAddress     String   @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent") @db.VarChar(512)
  success       Boolean
  failureReason String?  @map("failure_reason") @db.Text
  country       String?  @db.VarChar(100)
  city          String?  @db.VarChar(100)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([adminId])
  @@index([success])
  @@index([createdAt])
  @@map("admin_login_logs")
}

model IpWhitelist {
  id        String   @id @default(uuid()) @db.Uuid
  adminId   String   @map("admin_id") @db.Uuid
  ipAddress String   @map("ip_address") @db.VarChar(45)
  label     String?  @db.VarChar(100)
  addedBy   String   @map("added_by") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([adminId, ipAddress])
  @@index([adminId])
  @@map("ip_whitelist")
}
