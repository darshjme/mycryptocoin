// ──────────────────────────────────────────────
// Fraud Detection & Address Blacklist
// ──────────────────────────────────────────────

model FraudAlert {
  id                String             @id @default(uuid()) @db.Uuid
  merchantId        String             @map("merchant_id") @db.Uuid
  type              String             @db.VarChar(50)
  severity          String             @db.VarChar(20) // maps to FraudAlertSeverity in app code
  status            String             @default("active") @db.VarChar(30)
  title             String             @db.VarChar(255)
  description       String             @db.Text
  metadata          Json?
  recommendedAction String?            @map("recommended_action") @db.Text
  autoFrozen        Boolean            @default(false) @map("auto_frozen")
  notes             String?            @db.Text
  acknowledgedAt    DateTime?          @map("acknowledged_at")
  acknowledgedBy    String?            @map("acknowledged_by") @db.VarChar(255)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Restrict)

  @@index([merchantId])
  @@index([merchantId, status])        // getAlerts: merchantId + status filter
  @@index([status])
  @@index([severity])
  @@index([severity, status])          // getAlertCounts: severity groupBy where status=active
  @@index([type])
  @@index([createdAt])
