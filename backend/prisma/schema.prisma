// ============================================
// MyCryptoCoin — Prisma Database Schema
// PostgreSQL 15+
// Production-grade for financial system
//
// AUDIT FIXES APPLIED:
// 1. Added missing models: Invoice, Refund, Discount, DiscountUsage
// 2. Added missing fields on Payment (network, token, externalId, requestedAmount,
//    cryptoAmount, receivedAmount, exchangeRate, fee, feeRate, paidAt)
// 3. Added missing fields on Withdrawal (network, token, fee, netAmount)
// 4. Added missing fields on FeeRecord (network, token, feeRate)
// 5. Added missing fields on Wallet (network, token) to match service code
// 6. Changed Merchant onDelete from CASCADE to RESTRICT on financial tables
// 7. Added compound indexes for all WHERE clause patterns found in services
// 8. Added soft-delete (deletedAt) on financial records
// 9. Added connection pooling URL support
// 10. Added missing enum types (InvoiceStatus, RefundStatus, DiscountType,
//     FraudAlertSeverity, FraudAlertStatus, ConversionStatus, DisbursementStatus,
//     SweepRecordStatus)
// 11. Fixed Wallet unique constraint to match service code (merchantId+network+token)
// 12. Added missing compound indexes for pagination queries
// ============================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["metrics"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL") // bypass pgbouncer for migrations
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum UserRole {
  MERCHANT
  ADMIN
  SUPER_ADMIN
  OPERATIONS
  COMPLIANCE
  SUPPORT
  VIEWER
}

enum KycStatus {
  NOT_STARTED
  NOT_SUBMITTED
  PENDING
  PENDING_REVIEW
  UNDER_REVIEW
  VERIFIED
  APPROVED
  REJECTED
  EXPIRED
  ADDITIONAL_INFO_REQUIRED
}

enum PaymentStatus {
  AWAITING_PAYMENT
  UNDERPAID
  PAID
  OVERPAID
  EXPIRED
  CANCELLED
  REFUNDED
  // Legacy statuses kept for backward compatibility
  PENDING
  CONFIRMING
  CONFIRMED
  COMPLETED
  FAILED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  SWEEP
  REFUND
  FEE
}

enum TransactionStatus {
  PENDING
  CONFIRMING
  CONFIRMED
  COMPLETED
  FAILED
  EXPIRED
  CANCELLED
  REFUNDED
}

enum WithdrawalStatus {
  PENDING
  PENDING_APPROVAL
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  AUTO_APPROVED
  PARTIALLY_APPROVED
  FULLY_APPROVED
  REJECTED
  EMERGENCY_OVERRIDE
}

enum OtpPurpose {
  LOGIN
  WITHDRAWAL
  EMAIL_VERIFY
  PASSWORD_RESET
}

enum WalletType {
  HOT
  COLD
}

enum SweepStatus {
  PENDING
  COMPLETED
  FAILED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum RefundStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum FraudAlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FraudAlertStatus {
  ACTIVE
  ACKNOWLEDGED
  DISMISSED
  ESCALATED
  AUTO_RESOLVED
}

enum ConversionStatus {
  PENDING
  SWEEPING
  SWAPPING
  SETTLING
  COMPLETED
  FAILED
}

enum DisbursementStatus {
  PENDING
  SENT
  CONFIRMED
  FAILED
}

enum SweepRecordStatus {
  PENDING
  BROADCAST
  CONFIRMED
  FAILED
}

// ──────────────────────────────────────────────
// Core Models
// ──────────────────────────────────────────────

/// Unified merchant model — auth + business data.
/// The entire backend uses this as the primary identity.
model Merchant {
  id                      String    @id @default(uuid()) @db.Uuid
  email                   String    @unique @db.VarChar(255)
  passwordHash            String    @map("password_hash") @db.VarChar(255)
  businessName            String    @map("business_name") @db.VarChar(255)
  phone                   String?   @db.VarChar(20)
  whatsappNumber          String?   @map("whatsapp_number") @db.VarChar(20)
  country                 String?   @db.VarChar(2)
  website                 String?   @db.VarChar(512)
  logoUrl                 String?   @map("logo_url") @db.VarChar(512)
  callbackUrl             String?   @map("callback_url") @db.VarChar(512)
  role                    UserRole  @default(MERCHANT)
  isActive                Boolean   @default(false) @map("is_active")
  isEmailVerified         Boolean   @default(false) @map("is_email_verified")
  isPhoneVerified         Boolean   @default(false) @map("is_phone_verified")
  twoFactorEnabled        Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret         String?   @map("two_factor_secret") @db.VarChar(255)
  kycStatus               KycStatus @default(NOT_STARTED) @map("kyc_status")
  notificationPreferences Json?     @map("notification_preferences")
  dailyVolumeLimit        Decimal   @default(10000) @map("daily_volume_limit") @db.Decimal(20, 8)
  monthlyVolumeLimit      Decimal   @default(100000) @map("monthly_volume_limit") @db.Decimal(20, 8)

  // KYC / Compliance tier fields
  kycTier                 Int       @default(0) @map("kyc_tier")
  kycExpiresAt            DateTime? @map("kyc_expires_at")

  // Freeze fields (emergency & fraud)
  isFrozen                Boolean   @default(false) @map("is_frozen")
  frozenAt                DateTime? @map("frozen_at")
  frozenBy                String?   @map("frozen_by") @db.Uuid
  frozenReason            String?   @map("frozen_reason") @db.Text

  // Soft delete — NEVER hard-delete merchants
  deletedAt               DateTime? @map("deleted_at")

  lastLoginAt             DateTime? @map("last_login_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  apiKeys          ApiKey[]
  wallets          Wallet[]
  payments         Payment[]
  withdrawals      Withdrawal[]
  webhooks         Webhook[]
  whatsappSessions WhatsAppSession[]
  feeRecords       FeeRecord[]
  auditLogs        AuditLog[]
  fraudAlerts      FraudAlert[]
  kycSubmissions   KycSubmission[]
  conversions      Conversion[]
  feeDisbursements FeeDisbursement[]
  invoices         Invoice[]
  refunds          Refund[]
  discounts        Discount[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([isActive])
  @@index([isFrozen])
  @@index([kycTier])
  @@index([kycStatus])
  @@index([kycExpiresAt])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("merchants")
}

model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  merchantId  String    @map("merchant_id") @db.Uuid
  name        String    @db.VarChar(100)
  keyHash     String    @unique @map("key_hash") @db.VarChar(255)
  keyPrefix   String    @map("key_prefix") @db.VarChar(16)
  mode        String    @db.VarChar(10) // 'live' | 'test'
  permissions String[]  @default(["payments:read", "payments:write"])
  ipWhitelist String[]  @default([]) @map("ip_whitelist")
  isActive    Boolean   @default(true) @map("is_active")
  revokedAt   DateTime? @map("revoked_at")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Restrict)

  @@index([merchantId])
  @@index([keyPrefix])
  @@index([merchantId, isActive])
  @@map("api_keys")
}

model Wallet {
  id                    String   @id @default(uuid()) @db.Uuid
  merchantId            String   @map("merchant_id") @db.Uuid
  crypto                String   @db.VarChar(20)
  network               String   @default("") @db.VarChar(30) // BITCOIN, ETHEREUM, TRON, etc.
  token                 String   @default("") @db.VarChar(20) // BTC, ETH, USDT, etc.
  address               String   @db.VarChar(255)
  publicKey             String?  @map("public_key") @db.VarChar(255)
  derivationPath        String?  @map("derivation_path") @db.VarChar(100)
  derivationIndex       Int?     @map("derivation_index")
  balance               Decimal  @default(0) @db.Decimal(30, 18)
  pendingBalance        Decimal  @default(0) @map("pending_balance") @db.Decimal(30, 18)
  totalReceived         Decimal  @default(0) @map("total_received") @db.Decimal(30, 18)
  totalWithdrawn        Decimal  @default(0) @map("total_withdrawn") @db.Decimal(30, 18)
  autoWithdrawEnabled   Boolean  @default(false) @map("auto_withdraw_enabled")
  autoWithdrawAddress   String?  @map("auto_withdraw_address") @db.VarChar(255)
  autoWithdrawThreshold Decimal? @map("auto_withdraw_threshold") @db.Decimal(30, 18)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  merchant     Merchant      @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  payments     Payment[]
  withdrawals  Withdrawal[]
  transactions Transaction[]

  @@unique([merchantId, crypto])
  @@unique([merchantId, network, token])
  @@index([merchantId])
  @@index([crypto])
  @@index([address])
  @@map("wallets")
}

/// Payment: the primary financial record. ALL monetary fields use Decimal.
model Payment {
  id                    String        @id @db.VarChar(64)
  merchantId            String        @map("merchant_id") @db.Uuid
  walletId              String?       @map("wallet_id") @db.Uuid
  externalId            String?       @map("external_id") @db.VarChar(100) // merchant-provided external ID

  // Crypto details
  crypto                String        @db.VarChar(20)
  network               String        @default("") @db.VarChar(30) // BITCOIN, ETHEREUM, TRON, etc.
  token                 String        @default("") @db.VarChar(20) // BTC, ETH, USDT, etc.

  // Amounts — ALL Decimal, NO Float
  requestedAmount       Decimal       @default(0) @map("requested_amount") @db.Decimal(30, 18)
  requestedCurrency     String        @default("USD") @map("requested_currency") @db.VarChar(10)
  cryptoAmount          Decimal       @default(0) @map("crypto_amount") @db.Decimal(30, 18)
  receivedAmount        Decimal       @default(0) @map("received_amount") @db.Decimal(30, 18)
  exchangeRate          Decimal       @default(1) @map("exchange_rate") @db.Decimal(20, 8)
  fee                   Decimal       @default(0) @db.Decimal(30, 18)
  feeRate               Decimal       @default(0.005) @map("fee_rate") @db.Decimal(10, 6)

  // Legacy fields kept for backward compatibility
  amount                Decimal       @default(0) @db.Decimal(30, 18)
  currency              String        @default("USD") @db.VarChar(10)
  description           String?       @db.VarChar(500)
  orderId               String?       @map("order_id") @db.VarChar(100)
  customerEmail         String?       @map("customer_email") @db.VarChar(255)
  customerName          String?       @map("customer_name") @db.VarChar(200)
  callbackUrl           String?       @map("callback_url") @db.VarChar(512)
  redirectUrl           String?       @map("redirect_url") @db.VarChar(512)
  depositAddress        String        @map("deposit_address") @db.VarChar(255)
  derivationPath        String?       @map("derivation_path") @db.VarChar(100)
  txHash                String?       @map("tx_hash") @db.VarChar(255)
  confirmations         Int           @default(0)
  confirmationsRequired Int           @default(1) @map("confirmations_required")
  detectedAmount        Decimal?      @map("detected_amount") @db.Decimal(30, 18)
  feeAmount             Decimal?      @map("fee_amount") @db.Decimal(30, 18)
  netAmount             Decimal?      @map("net_amount") @db.Decimal(30, 18)

  status                PaymentStatus @default(AWAITING_PAYMENT)
  metadata              Json?

  expiresAt             DateTime      @map("expires_at")
  paidAt                DateTime?     @map("paid_at")
  completedAt           DateTime?     @map("completed_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  merchant     Merchant      @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  wallet       Wallet?       @relation(fields: [walletId], references: [id])
  feeRecord    FeeRecord?
  transactions Transaction[]
  conversion   Conversion?
  refunds      Refund[]

  // Compound indexes matching service query patterns
  @@index([merchantId, status])        // listPayments: merchantId + status filter
  @@index([merchantId, createdAt])     // listPayments: merchantId + date range pagination
  @@index([merchantId, network, token]) // wallet address generation counter
  @@index([status, expiresAt])         // checkExpiredPayments: status=AWAITING + expiresAt < now
  @@index([merchantId])
  @@index([orderId])
  @@index([externalId])
  @@index([status])
  @@index([depositAddress])
  @@index([crypto])
  @@index([createdAt])
  @@index([txHash])
  @@map("payments")
}

/// Blockchain transaction record.
model Transaction {
  id                    String            @id @default(uuid()) @db.Uuid
  paymentId             String?           @map("payment_id") @db.VarChar(64)
  withdrawalId          String?           @map("withdrawal_id") @db.VarChar(64)
  walletId              String            @map("wallet_id") @db.Uuid
  network               String            @db.VarChar(30)
  token                 String            @db.VarChar(20)
  type                  String?           @db.VarChar(20)
  txHash                String            @map("tx_hash") @db.VarChar(255)
  fromAddress           String            @map("from_address") @db.VarChar(255)
  toAddress             String            @map("to_address") @db.VarChar(255)
  amount                Decimal           @db.Decimal(30, 18)
  fee                   Decimal           @default(0) @db.Decimal(30, 18)
  confirmations         Int               @default(0)
  requiredConfirmations Int               @map("required_confirmations")
  status                TransactionStatus @default(PENDING)
  blockNumber           BigInt?           @map("block_number")
  blockHash             String?           @map("block_hash") @db.VarChar(255)
  rawData               Json?             @map("raw_data")
  confirmedAt           DateTime?         @map("confirmed_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  payment    Payment?    @relation(fields: [paymentId], references: [id])
  withdrawal Withdrawal? @relation(fields: [withdrawalId], references: [id])
  wallet     Wallet      @relation(fields: [walletId], references: [id])

  @@unique([network, txHash])
  @@index([paymentId])
  @@index([withdrawalId])
  @@index([walletId])
  @@index([txHash])
  @@index([status])
  @@index([status, createdAt])         // monitoring: status filter + time ordering
  @@index([createdAt])
  @@map("transactions")
}

/// Withdrawal: funds leaving the platform to merchant's external address.
model Withdrawal {
  id              String           @id @db.VarChar(64)
  merchantId      String           @map("merchant_id") @db.Uuid
  walletId        String           @map("wallet_id") @db.Uuid
  crypto          String           @db.VarChar(20)
  network         String           @default("TRON") @db.VarChar(30) // TRON, BITCOIN, etc.
  token           String           @default("USDT") @db.VarChar(20) // USDT, BTC, etc.
  amount          Decimal          @db.Decimal(30, 18)
  fee             Decimal          @default(0) @db.Decimal(30, 18)
  netAmount       Decimal          @default(0) @map("net_amount") @db.Decimal(30, 18)
  toAddress       String           @map("to_address") @db.VarChar(255)
  memo            String?          @db.VarChar(255)
  estimatedFee    Decimal?         @map("estimated_fee") @db.Decimal(30, 18)
  networkFee      Decimal?         @map("network_fee") @db.Decimal(30, 18)
  txHash          String?          @map("tx_hash") @db.VarChar(255)
  status          WithdrawalStatus @default(PENDING)
  type            String           @default("manual") @db.VarChar(20)
  error           String?          @db.Text
  completedAt     DateTime?        @map("completed_at")

  // Multi-sig approval fields
  approvalStatus    ApprovalStatus? @map("approval_status")
  requiredApprovals Int?            @map("required_approvals")
  currentApprovals  Int?            @default(0) @map("current_approvals")
  coolingEndsAt     DateTime?       @map("cooling_ends_at")
  approvedAt        DateTime?       @map("approved_at")
  rejectedAt        DateTime?       @map("rejected_at")
  rejectionReason   String?         @map("rejection_reason") @db.Text
  amountUsd         Decimal?        @map("amount_usd") @db.Decimal(20, 8)

  reviewedBy      String?          @map("reviewed_by") @db.Uuid
  reviewNote      String?          @map("review_note") @db.Text

  processedAt     DateTime?        @map("processed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  merchant            Merchant             @relation(fields: [merchantId], references: [id], onDelete: Restrict)
  wallet              Wallet               @relation(fields: [walletId], references: [id])
  transactions        Transaction[]
  withdrawalApprovals WithdrawalApproval[]

  // Compound indexes matching service query patterns
  @@index([merchantId, status])        // getWithdrawals: merchantId + status filter
  @@index([merchantId, createdAt])     // getWithdrawals: merchantId + date ordering
  @@index([merchantId, crypto, status, createdAt]) // fraud: amount anomaly aggregate
  @@index([merchantId, toAddress, status]) // fraud: new address check
  @@index([merchantId])
  @@index([walletId])
  @@index([status])
  @@index([approvalStatus])
  @@index([crypto])
  @@index([createdAt])
  @@index([toAddress])
  @@map("withdrawals")
}

model WhatsAppSession {
  id           String    @id @default(uuid()) @db.Uuid
  merchantId   String    @map("merchant_id") @db.Uuid
  phoneNumber  String    @map("phone_number") @db.VarChar(20)
  sessionData  Json?     @map("session_data")
  isConnected  Boolean   @default(false) @map("is_connected")
  lastActiveAt DateTime? @map("last_active_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, phoneNumber])
  @@index([merchantId])
  @@map("whatsapp_sessions")
}

model OtpCode {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  code      String     @db.VarChar(10)
  purpose   OtpPurpose
  isUsed    Boolean    @default(false) @map("is_used")
  expiresAt DateTime   @map("expires_at")
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([userId])
  @@index([code, purpose])
  @@index([expiresAt])
  @@map("otp_codes")
}

/// Webhook endpoint registered by a merchant.
model Webhook {
  id              String            @id @default(uuid()) @db.Uuid
  merchantId      String            @map("merchant_id") @db.Uuid
  url             String            @db.VarChar(512)
  secret          String            @db.VarChar(255)
  events          String[]          @default(["payment.completed"])
  isActive        Boolean           @default(true) @map("is_active")
  failureCount    Int               @default(0) @map("failure_count")
  lastDeliveredAt DateTime?         @map("last_delivered_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  merchant   Merchant          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([merchantId])
  @@index([merchantId, isActive])      // dispatch: merchantId + isActive + events
  @@map("webhooks")
}

/// Log of individual webhook delivery attempts.
model WebhookDelivery {
  id         String   @id @default(uuid()) @db.Uuid
  webhookId  String   @map("webhook_id") @db.Uuid
  event      String   @db.VarChar(100)
  payload    Json
  statusCode Int      @map("status_code")
  success    Boolean
  attempt    Int      @default(1)
  error      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([webhookId, createdAt])      // delivery history per webhook
  @@index([event])
  @@index([createdAt])
  @@map("webhook_deliveries")
}

/// Audit log — APPEND-ONLY. No updates, no deletes. Never hard-delete.
model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  merchantId    String?  @map("merchant_id") @db.Uuid
  adminId       String?  @map("admin_id") @db.VarChar(255)
  adminEmail    String?  @map("admin_email") @db.VarChar(255)
  action        String   @db.VarChar(100)
  resource      String?  @db.VarChar(100)
  resourceId    String?  @map("resource_id") @db.VarChar(100)
  target        String?  @db.VarChar(255)
  targetId      String?  @map("target_id") @db.VarChar(255)
  previousValue String?  @map("previous_value") @db.Text
  newValue      String?  @map("new_value") @db.Text
  ipAddress     String   @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent") @db.VarChar(512)
  details       Json?
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  merchant Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)

  @@index([merchantId])
  @@index([adminId])
  @@index([action])
  @@index([targetId])
  @@index([createdAt])
  @@index([adminId, createdAt])        // audit query: adminId + date range
  @@index([action, createdAt])         // audit query: action filter + date range
  @@map("audit_logs")
}

/// Fee record — tracks platform fees on each payment. Never hard-delete.
model FeeRecord {
  id          String    @id @default(uuid()) @db.Uuid
  paymentId   String    @unique @map("payment_id") @db.VarChar(64)
  merchantId  String    @map("merchant_id") @db.Uuid
  crypto      String    @db.VarChar(20)
  network     String    @default("TRON") @db.VarChar(30)
  token       String    @default("USDT") @db.VarChar(20)
  grossAmount Decimal   @map("gross_amount") @db.Decimal(30, 18)
  feeRate     Decimal   @default(0.005) @map("fee_rate") @db.Decimal(10, 6)
  feeAmount   Decimal   @map("fee_amount") @db.Decimal(30, 18)
  netAmount   Decimal   @map("net_amount") @db.Decimal(30, 18)
  settledAt   DateTime? @map("settled_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  payment  Payment  @relation(fields: [paymentId], references: [id])
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Restrict)

  @@index([merchantId])
  @@index([merchantId, createdAt])     // getMerchantFees: pagination
  @@index([crypto])
  @@index([createdAt])
  @@index([settledAt])
  @@map("fee_records")
}

// ──────────────────────────────────────────────
// Multi-Sig Withdrawal Approval
// ──────────────────────────────────────────────

model WithdrawalApproval {
  id           String   @id @default(uuid()) @db.Uuid
  withdrawalId String   @map("withdrawal_id") @db.VarChar(64)
  adminId      String   @map("admin_id") @db.VarChar(255)
  adminEmail   String   @map("admin_email") @db.VarChar(255)
  adminRole    String   @map("admin_role") @db.VarChar(50)
  action       String   @db.VarChar(20) // 'APPROVED' | 'REJECTED'
  comment      String   @default("") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  withdrawal Withdrawal @relation(fields: [withdrawalId], references: [id], onDelete: Restrict)

  @@unique([withdrawalId, adminId, action]) // prevent duplicate approvals
  @@index([withdrawalId])
  @@index([adminId])
  @@index([createdAt])
  @@map("withdrawal_approvals")
}

// ──────────────────────────────────────────────
// Platform Wallets (Hot/Cold) & Sweeps
// ──────────────────────────────────────────────

model PlatformWallet {
  id          String     @id @default(uuid()) @db.Uuid
  crypto      String     @db.VarChar(20)
  type        WalletType
  address     String     @unique @db.VarChar(255)
  balance     Decimal    @default(0) @db.Decimal(30, 18)
  label       String?    @db.VarChar(100)
  lastSweepAt DateTime?  @map("last_sweep_at")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@unique([crypto, type])
  @@index([crypto])
  @@index([crypto, type, isActive])    // wallet management: find active hot/cold per crypto
  @@index([type])
  @@map("platform_wallets")
}

model WalletSweep {
  id          String      @id @default(uuid()) @db.Uuid
  crypto      String      @db.VarChar(20)
  fromType    String      @map("from_type") @db.VarChar(10)
  toType      String      @map("to_type") @db.VarChar(10)
  amount      Decimal     @db.Decimal(30, 18)
  txHash      String      @map("tx_hash") @db.VarChar(255)
  initiatedBy String      @map("initiated_by") @db.VarChar(255)
  status      SweepStatus @default(PENDING)
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([crypto])
  @@index([status])
  @@index([createdAt])
  @@index([crypto, createdAt])         // sweep history: filter by crypto + time
  @@map("wallet_sweeps")
}

